    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch DirectX11 RHI - Debug",
            "type":"lldb",
            "request": "launch",
            "program": "${workspaceRoot}/Binary/Debug/MagicRHI.exe",
            "args": ["dx11"],
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal", 
        },
        {
            "name": "Launch DirectX12 RHI - Debug",
            "type":"lldb",
            "request": "launch",
            "program": "${workspaceRoot}/Binary/Debug/MagicRHI.exe",
            "args": ["dx12"],
            "cwd": "${workspaceRoot}",
            "console": "integratedTerminal", 
        },
        {
            "name": "Launch DirectX11 RHI - Release",
            "type":"lldb",
            "request": "launch",
            "program": "${workspaceRoot}/Binary/Release/MagicRHI.exe",
            "args": ["dx11"],
            "cwd": "${workspaceRoot}"
        },
        {
            "name": "Launch DirectX12 RHI - Release",
            "type":"lldb",
            "request": "launch",
            "program": "${workspaceRoot}/Binary/Release/MagicRHI.exe",
            "args": ["dx12"],
            "cwd": "${workspaceRoot}"
        }
    ]

    // ============================================================
    // 此配置依赖以下插件才能正常工作：
    //    - kylinideteam.cmake-intellisence
    //    - vadimcn.vscode-lldb
    //    - franneck94.c-cpp-runner
    //    - nilssoderman.batch-runner
    // ============================================================
}